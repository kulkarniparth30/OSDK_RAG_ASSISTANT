# ─── LLM Configuration ────────────────────────────────────────────────────────
# Option 1 (Recommended): OpenAI — get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Option 2: Use local Ollama (no API key needed, install Ollama first)
# Set USE_OLLAMA=true and make sure `ollama run llama3.2:3b` is running
USE_OLLAMA=false
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
